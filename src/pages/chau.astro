---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Baja de Alertas" description="Interrumpir transmisión de alertas de Calendarium.tech">
  <div class="max-w-md mx-auto py-20 px-4 text-center">
    
    <div id="processing-state">
      <div class="w-16 h-16 border-4 border-yellow-400/20 border-t-yellow-400 rounded-full animate-spin mx-auto mb-8"></div>
      <h1 class="text-2xl font-black italic uppercase text-white tracking-tighter">
        Procesando <span class="text-yellow-400">Baja...</span>
      </h1>
      <p class="text-white/40 text-xs mt-4 uppercase tracking-widest">Desconectando del búnker</p>
    </div>

    <div id="success-state" class="hidden animate-in fade-in zoom-in duration-500">
      <div class="w-20 h-20 bg-red-500/10 rounded-full flex items-center justify-center mx-auto mb-8 border border-red-500/20">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M18.36 6.64a9 9 0 1 1-12.73 0"></path><line x1="12" y1="2" x2="12" y2="12"></line></svg>
      </div>
      <h1 class="text-3xl font-black italic uppercase text-white tracking-tighter mb-4">
        Transmisión <span class="text-red-500">Interrumpida</span>
      </h1>
      <p class="text-white/60 text-sm uppercase tracking-widest leading-relaxed mb-8">
        Tu email ha sido removido de la lista activa.<br/>No recibirás más comandos de nuestra parte.
      </p>
      <a href="/" class="inline-block text-[10px] font-black uppercase tracking-widest text-yellow-400 border-b border-yellow-400/20 hover:border-yellow-400 transition-all">
        Volver a la Terminal Principal
      </a>
    </div>

    <div id="error-state" class="hidden">
      <h1 class="text-xl font-black italic uppercase text-white mb-4">Error de Sincronización</h1>
      <p class="text-white/40 text-xs uppercase tracking-widest mb-8">No pudimos procesar la baja automáticamente.</p>
      <a href="/contacto" class="text-yellow-400 font-bold uppercase text-[10px]">Contactar a Soporte</a>
    </div>

  </div>

  <script>
    import { supabase } from '../lib/supabase';

    async function handleUnsubscribe() {
      const processing = document.getElementById('processing-state');
      const success = document.getElementById('success-state');
      const errorState = document.getElementById('error-state');

      // 1. Obtener el email de la URL
      const urlParams = new URLSearchParams(window.location.search);
      const email = urlParams.get('email');

      if (!email) {
        if (processing) processing.classList.add('hidden');
        if (errorState) errorState.classList.add('block');
        return;
      }

      try {
        // 2. Actualizar la base de datos
        const { error } = await supabase
          .from('subscriptions')
          .update({ is_active: false })
          .eq('email', email);

        if (error) throw error;

        // 3. Mostrar éxito
        if (processing) processing.classList.add('hidden');
        if (success) success.classList.remove('hidden');

      } catch (err) {
        console.error('Error:', err);
        if (processing) processing.classList.add('hidden');
        if (errorState) errorState.classList.remove('hidden');
      }
    }

    // Ejecutar al cargar
    handleUnsubscribe();
    document.addEventListener('astro:page-load', handleUnsubscribe);
  </script>
</MainLayout>