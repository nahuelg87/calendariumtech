---
export const prerender = true;
import MainLayout from "../../layouts/MainLayout.astro";
---

<MainLayout title="Panel de Control">
  <div class="max-w-6xl mx-auto p-6">
    
    <div id="loading-overlay" class="py-20 text-center">
      <div class="w-12 h-12 border-4 border-yellow-400/20 border-t-yellow-400 rounded-full animate-spin mx-auto mb-4"></div>
      <p class="text-white/40 text-[10px] font-black uppercase tracking-[0.3em]">Sincronizando Búnker...</p>
    </div>

    <div id="admin-content" class="hidden">
      <header class="flex justify-between items-center mb-12">
        <div>
          <h1 class="text-4xl font-black italic text-white tracking-tighter">DASHBOARD</h1>
          <p id="event-counter" class="text-white/50 font-mono text-[10px] uppercase tracking-widest mt-1">
            Cargando telemetría...
          </p>
        </div>
        <div class="flex gap-4">
          <a href="/admin/nuevo" class="bg-[#facc15] text-black font-black italic px-6 py-3 rounded-xl hover:bg-white transition-all shadow-[0_0_20px_rgba(250,204,21,0.2)] text-sm">
            + NUEVO EVENTO
          </a>
          <button id="logout-btn" class="border border-white/10 text-white/50 px-6 py-3 rounded-xl hover:bg-red-500/20 hover:text-red-500 transition-all font-bold text-xs uppercase tracking-widest">
            Salir
          </button>
        </div>
      </header>

      <div id="events-container" class="grid gap-4">
        </div>
    </div>
  </div>
</MainLayout>

<script>
  import { supabase } from "../../lib/supabase";

  const loadingOverlay = document.getElementById('loading-overlay');
  const adminContent = document.getElementById('admin-content');
  const eventsContainer = document.getElementById('events-container');
  const eventCounter = document.getElementById('event-counter');
  const logoutBtn = document.getElementById('logout-btn');

  async function initDashboard() {
    console.log("--- Iniciando Sincronización del Búnker ---");
    
    // 1. Verificación de Seguridad
    const { data: { session } } = await supabase.auth.getSession();
    
    if (!session) {
      window.location.href = '/login';
      return;
    }

    // 2. Carga de Datos (con bypass de caché manual)
    const { data: events, error } = await supabase
      .from("events")
      .select(`*, event_tags (track_name)`)
      .order("created_at", { ascending: false });

    if (error) {
      console.error("Error de conexión Supabase:", error.message);
      return;
    }

    // DEBUG: Para que veas en la consola si los datos llegan actualizados
    console.log("Eventos recibidos:", events);

    // 3. Renderizado
    renderEvents(events || []);
    
    // 4. Interfaz
    loadingOverlay?.classList.add('hidden');
    adminContent?.classList.remove('hidden');
  }

  function renderEvents(events: any[]) {
    if (!eventsContainer) return;

    if (events.length === 0) {
      eventsContainer.innerHTML = `
        <div class="py-20 text-center border-2 border-dashed border-white/5 rounded-3xl">
          <p class="text-white/20 uppercase tracking-widest text-xs font-bold italic">No hay misiones activas</p>
        </div>
      `;
      if (eventCounter) eventCounter.innerText = "0 EVENTOS ACTIVOS";
      return;
    }

    if (eventCounter) eventCounter.innerText = `${events.length} EVENTOS EN EL BÚNKER`;

    eventsContainer.innerHTML = events.map(event => {
      const tracksList = event.event_tags?.map((t: any) => t.track_name) || [];
      const displayTracks = tracksList.length > 0 ? tracksList.join(" • ") : "Sin categoría";
      
      // Manejo de fecha para evitar desfases de zona horaria
      const eventDate = new Date(event.date + 'T12:00:00');

      return `
        <div class="bg-[#111] border border-white/5 p-4 rounded-2xl flex items-center justify-between group hover:border-[#22d3ee]/30 transition-all duration-500">
          <div class="flex items-center gap-6">
            <div class="w-14 h-14 bg-white/5 border border-white/10 rounded-xl flex flex-col items-center justify-center group-hover:border-[#facc15]/50 transition-colors">
              <span class="text-[#facc15] font-black text-xl leading-none">${event.date.split('-')[2]}</span>
              <span class="text-white/30 text-[9px] font-bold uppercase">${eventDate.toLocaleString('es', { month: 'short' })}</span>
            </div>

            <div>
              <h3 class="text-white font-bold text-lg group-hover:text-[#facc15] transition-colors">${event.title}</h3>
              <p class="text-[10px] text-white/30 uppercase tracking-[0.2em] font-medium">
                <span class="text-[#22d3ee]">${displayTracks}</span> — ${event.location}
              </p>
            </div>
          </div>

          <div class="flex gap-2 opacity-0 group-hover:opacity-100 transition-all translate-x-4 group-hover:translate-x-0">
            <a href="/admin/editar?id=${event.id}" class="p-3 text-white/30 hover:text-[#22d3ee] transition-colors" title="Editar">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
            </a>
            <button onclick="window.deleteEvent('${event.id}')" class="p-3 text-white/30 hover:text-red-500 transition-colors" title="Eliminar">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"></path><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"></path><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"></path></svg>
            </button>
          </div>
        </div>
      `;
    }).join('');
  }

  // Lógica Global de Borrado
  (window as any).deleteEvent = async (id: string) => {
    if (!confirm('¿Borrar misión definitivamente?')) return;
    try {
      await supabase.from('event_tags').delete().eq('event_id', id);
      const { error } = await supabase.from('events').delete().eq('id', id);
      if (error) throw error;
      initDashboard();
    } catch (err) {
      alert("Error en la purga de datos");
    }
  };

  logoutBtn?.addEventListener('click', async () => {
    await supabase.auth.signOut();
    window.localStorage.clear();
    window.location.href = '/login';
  });

  // Listener para Astro y para "Back" del navegador
  document.addEventListener('astro:page-load', initDashboard);
  window.addEventListener('pageshow', (event) => {
    if (event.persisted) initDashboard();
  });

  // Ejecución inmediata por si no hay transiciones de Astro
  initDashboard();
</script>

<style>
  @reference "../../styles/global.css";
</style>