---
import MainLayout from '../layouts/MainLayout.astro';
const tracks = ['A.I.', 'Cloud', 'CyberSecurity', 'Data Science', 'Dev', 'DevOps', 'Leadership', 'Mobile', 'Networking', 'Varios', 'Web3 / Blockchain'];
---

<MainLayout title="Sumar Evento" description="Propone un evento para la comunidad de Calendarium.tech">
  <div class="max-w-2xl mx-auto py-8 px-4">
    
    <div class="mb-12 text-center md:text-left">
      <h1 class="text-4xl font-black italic uppercase tracking-tighter text-white mb-4">
        Sumar <span class="text-yellow-400">Evento</span>
      </h1>
      <p class="text-white/60 text-sm uppercase tracking-widest font-bold">
        Completá la data para que el administrador la revise y la sume al búnker.
      </p>
    </div>

    <form id="proposal-form" class="space-y-6 bg-white/5 p-8 rounded-2xl border border-white/10 backdrop-blur-sm">
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="space-y-2">
          <label class="text-[10px] uppercase font-black tracking-widest text-yellow-400/80">Nombre del Evento</label>
          <input type="text" name="title" class="w-full bg-black/40 border border-white/10 rounded-xl px-4 py-3 text-white focus:border-yellow-400/50 outline-none transition-all" required placeholder="Ej: Meetup JS BUE" />
        </div>

        <div class="space-y-2">
          <label class="text-[10px] uppercase font-black tracking-widest text-yellow-400/80">Fecha</label>
          <input type="date" name="date" class="w-full bg-black/40 border border-white/10 rounded-xl px-4 py-3 text-white focus:border-yellow-400/50 outline-none transition-all" required />
        </div>
      </div>

      <div class="space-y-2">
        <label class="text-[10px] uppercase font-black tracking-widest text-yellow-400/80">Link de Inscripción / Info</label>
        <input type="url" name="link_url" class="w-full bg-black/40 border border-white/10 rounded-xl px-4 py-3 text-white focus:border-yellow-400/50 outline-none transition-all" required placeholder="https://..." />
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="space-y-2">
          <label class="text-[10px] uppercase font-black tracking-widest text-yellow-400/80">Ubicación</label>
          <input type="text" name="location" class="w-full bg-black/40 border border-white/10 rounded-xl px-4 py-3 text-white focus:border-yellow-400/50 outline-none transition-all" required placeholder="Online / CABA / etc" />
        </div>

        <div class="space-y-2">
          <label class="text-[10px] uppercase font-black tracking-widest text-yellow-400/80">Track Sugerido</label>
          <div class="relative">
            <select name="track_suggested" class="w-full bg-black/40 border border-white/10 rounded-xl px-4 py-3 text-white/80 text-xs font-bold uppercase appearance-none focus:border-yellow-400/50 outline-none transition-all cursor-pointer">
              {tracks.map(t => <option value={t}>{t}</option>)}
            </select>
            <div class="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-white/20 text-[10px]">▼</div>
          </div>
        </div>
      </div>

      <div class="space-y-2">
        <label class="text-[10px] uppercase font-black tracking-widest text-yellow-400/80">Tu Email (Por si tenemos dudas)</label>
        <input type="email" name="user_email" class="w-full bg-black/40 border border-white/10 rounded-xl px-4 py-3 text-white focus:border-yellow-400/50 outline-none transition-all" required />
      </div>

      <div class="hidden" aria-hidden="true">
        <input type="text" name="bunker_trap" tabindex="-1" autocomplete="off" />
      </div>

      <button type="submit" class="w-full py-4 bg-yellow-400 text-black font-black uppercase italic tracking-widest rounded-xl hover:bg-white transition-all shadow-[0_0_20px_rgba(250,204,21,0.2)] active:scale-95">
        Enviar Propuesta
      </button>
    </form>

  </div>

  <script>
    import { supabase } from '../lib/supabase';

    function setupProposalForm() {
      const form = document.getElementById('proposal-form') as HTMLFormElement;
      if (!form) return;

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const formData = new FormData(form);
        
        if (formData.get('bunker_trap')) return;

        const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
        submitBtn.disabled = true;
        submitBtn.textContent = 'Enviando comando...';

        const { error } = await supabase.from('event_proposals').insert([{
          title: formData.get('title'),
          date: formData.get('date'),
          location: formData.get('location'),
          link_url: formData.get('link_url'),
          track_suggested: formData.get('track_suggested'),
          user_email: formData.get('user_email')
        }]);

        if (!error) {
          form.innerHTML = `
            <div class="text-center py-12 space-y-4">
              <h2 class="text-2xl font-black italic uppercase text-white">¡Propuesta Recibida!</h2>
              <p class="text-white/60 text-sm uppercase tracking-widest">Nahuel revisará los datos y lo sumará a la brevedad.</p>
              <a href="/" class="inline-block mt-6 text-yellow-400 font-bold border-b border-yellow-400/20 hover:border-yellow-400 transition-all text-xs uppercase tracking-widest">Volver al inicio</a>
            </div>
          `;
        } else {
          alert('Error al enviar la propuesta. Intentalo de nuevo.');
          submitBtn.disabled = false;
          submitBtn.textContent = 'Enviar Propuesta';
        }
      });
    }

    setupProposalForm();
    document.addEventListener('astro:page-load', setupProposalForm);
  </script>
</MainLayout>