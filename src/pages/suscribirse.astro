---
import MainLayout from '../layouts/MainLayout.astro';
import { supabase } from '../lib/supabase';

// 1. Traemos los tracks directamente de la tabla maestra 'tracks'
const { data: tracksData, error: fetchError } = await supabase
    .from('tracks')
    .select('name')
    .order('name', { ascending: true });

// 2. Procesamos para tener un array simple de strings
// Si falla o está vacío, ponemos 'General' como fallback de seguridad
const tracks = tracksData && tracksData.length > 0 
    ? tracksData.map(t => t.name) 
    : ['General'];

if (fetchError) {
    console.error("Error recuperando tracks:", fetchError.message);
}
---

<MainLayout title="Recibir Alertas" description="Configurá tus preferencias para no perderte ningún evento tech.">
  <div class="max-w-2xl mx-auto py-8">
    
    <div class="mb-12 text-center md:text-left">
      <h1 class="text-4xl font-black italic uppercase tracking-tighter text-white mb-4">
        Alertas <span class="text-yellow-400">Personalizadas</span>
      </h1>
      <p class="text-white/60 text-sm uppercase tracking-widest font-bold">
        Elegí tus tracks y recibí solo lo que te interesa.
      </p>
    </div>

    <form id="subscribe-form" class="space-y-8 bg-white/5 p-8 rounded-2xl border border-white/10 backdrop-blur-sm">
      
      <div class="space-y-2">
        <label for="email" class="text-[10px] uppercase font-black tracking-[0.2em] text-yellow-400/80 ml-1">
          Tu Email de comando
        </label>
        <input 
          type="email" 
          id="email" 
          name="email"
          placeholder="admin@tuempresa.tech" 
          class="w-full bg-black/40 border border-white/10 rounded-xl px-4 py-4 text-white placeholder:text-white/20 focus:outline-none focus:border-yellow-400/50 transition-all"
          required
        />
      </div>

      <div class="space-y-4">
        <label class="text-[10px] uppercase font-black tracking-[0.2em] text-yellow-400/80 ml-1">
          Seleccioná tus Tracks ({tracks.length})
        </label>
        
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          {tracks.map((track) => (
            <label class="flex items-center gap-3 p-4 bg-black/20 border border-white/5 rounded-xl cursor-pointer hover:border-white/20 transition-all group">
              <input 
                type="checkbox" 
                name="tracks" 
                value={track} 
                class="w-4 h-4 accent-yellow-400 border-white/20 bg-black rounded" 
              />
              <span class="text-xs font-bold uppercase tracking-widest text-white/60 group-hover:text-white transition-colors">
                {track}
              </span>
            </label>
          ))}
        </div>
      </div>

      <div class="space-y-4">
        <label for="frequency" class="text-[10px] uppercase font-black tracking-[0.2em] text-yellow-400/80 ml-1">
          Frecuencia de Alerta
        </label>
        
        <div class="relative">
          <select 
            id="frequency"
            name="frequency"
            class="w-full bg-black/40 border border-white/10 rounded-xl px-4 py-4 text-white/80 text-xs font-bold uppercase tracking-widest appearance-none focus:border-yellow-400/50 transition-all cursor-pointer"
          >
            <option value="diario">Diario (si hay novedades)</option>
            <option value="semanal" selected>Semanal (Cada Lunes)</option>
            <option value="quincenal">Quincenal (Cada 15 días)</option>
          </select>
          
          <div class="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-white/20 text-xs">
             ▼
          </div>
        </div>
      </div>

      <div class="hidden" aria-hidden="true">
        <input type="text" name="bunker_trap" tabindex="-1" autocomplete="off" />
      </div>

      <button 
        type="submit" 
        class="w-full py-4 bg-yellow-400 text-black font-black uppercase italic tracking-widest rounded-xl hover:bg-white hover:scale-[1.02] transition-all shadow-[0_0_20px_rgba(250,204,21,0.2)]"
      >
        Activar Alertas
      </button>
    </form>

    <p class="mt-8 text-[9px] text-center text-white/30 uppercase tracking-[0.3em]">
      Sin spam. Solo data técnica pura de Calendarium.tech.
    </p>

  </div>

  <script>
    import { supabase } from '../lib/supabase';

    function setupSubscriptionForm() {
      const form = document.getElementById('subscribe-form') as HTMLFormElement;
      
      if (!form) return;

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const formData = new FormData(form);
        
        // Verificación de Honeypot
        if (formData.get('bunker_trap')) {
          console.warn('Bot detected');
          return;
        }

        const email = formData.get('email');
        const tracks = formData.getAll('tracks');
        const frequency = formData.get('frequency');

        if (tracks.length === 0) {
          alert('Por favor, seleccioná al menos un track para recibir alertas.');
          return;
        }

        const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
        if (submitBtn) {
          submitBtn.disabled = true;
          submitBtn.textContent = 'Procesando comando...';
        }

        try {
          const { error } = await supabase
            .from('subscriptions')
            .insert([{ email, tracks, frequency }]);

          if (error) throw error;

          // Feedback de éxito
          form.innerHTML = `
            <div class="text-center py-12 space-y-6 animate-in fade-in zoom-in duration-500">
              <div class="w-20 h-20 bg-green-500/20 rounded-full flex items-center justify-center mx-auto border border-green-500/50">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
              </div>
              <h2 class="text-2xl font-black italic uppercase text-white">¡Suscripción Activada!</h2>
              <p class="text-white/60 text-sm uppercase tracking-widest leading-relaxed">
                El búnker ha registrado tu email.<br/>Pronto recibirás las novedades de tus tracks.
              </p>
              <a href="/" class="inline-block mt-4 text-[10px] font-black uppercase tracking-widest text-yellow-400 border-b border-yellow-400/30 hover:border-yellow-400 transition-all">
                Volver a la terminal de eventos
              </a>
            </div>
          `;
        } catch (err: any) {
          console.error('Error en suscripción:', err);
          alert('Hubo un error al registrar la suscripción. ¿Quizás ya estás registrado con este email?');
          
          if (submitBtn) {
            submitBtn.disabled = false;
            submitBtn.textContent = 'Activar Alertas';
          }
        }
      });
    }

    // Aseguramos la carga en todos los ciclos de vida de Astro
    setupSubscriptionForm();
    document.addEventListener('astro:after-swap', setupSubscriptionForm);
    document.addEventListener('astro:page-load', setupSubscriptionForm);
  </script>
</MainLayout>