---
// src/components/Navbar.astro
---
<header class="fixed top-0 w-full z-[100] border-b border-white/5 bg-black/60 backdrop-blur-xl">
  <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
    
    <a href="/" class="flex items-center gap-2 group">
      <div class="w-8 h-8 bg-yellow-400 rounded-lg flex items-center justify-center shadow-[0_0_15px_rgba(250,204,21,0.3)] group-hover:scale-110 transition-transform">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="black" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
          <line x1="16" y1="2" x2="16" y2="6"></line>
          <line x1="8" y1="2" x2="8" y2="6"></line>
          <line x1="3" y1="10" x2="21" y2="10"></line>
        </svg>
      </div>
      <span class="text-white font-black italic uppercase tracking-tighter text-lg">
        Calendarium<span class="text-yellow-400">.tech</span>
      </span>
    </a>

    <nav class="hidden md:flex items-center gap-8">
      <a href="/" class="text-white/60 hover:text-white text-xs font-bold uppercase tracking-widest transition-colors">Eventos</a>
      <a href="#" class="text-white/60 hover:text-white text-xs font-bold uppercase tracking-widest transition-colors">Comunidad</a>
      <a href="https://github.com" target="_blank" class="px-5 py-2 bg-white text-black text-[10px] font-black uppercase italic rounded-full hover:bg-yellow-400 transition-all duration-300">
        GitHub
      </a>
    </nav>

    <button id="menu-toggle" class="md:hidden text-white p-2 focus:outline-none" aria-label="Abrir menú">
      <svg id="menu-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="transition-transform duration-300">
        <line x1="3" y1="12" x2="21" y2="12" class="line-mid"></line>
        <line x1="3" y1="6" x2="21" y2="6" class="line-top"></line>
        <line x1="3" y1="18" x2="21" y2="18" class="line-bot"></line>
      </svg>
    </button>
  </div>

<div 
    id="mobile-menu" 
    class="absolute top-16 left-0 w-full bg-black/95 border-b border-white/10 backdrop-blur-2xl overflow-hidden transition-all duration-300 ease-in-out opacity-0 invisible -translate-y-4 pointer-events-none md:hidden"
  >
    <nav class="flex flex-col p-8 gap-6">
      <a href="/" class="text-white/70 hover:text-yellow-400 text-sm font-bold uppercase tracking-widest transition-colors">
        Eventos
      </a>
      <a href="#" class="text-white/70 hover:text-yellow-400 text-sm font-bold uppercase tracking-widest transition-colors">
        Comunidad
      </a>
      <a href="https://github.com" target="_blank" class="text-white/70 hover:text-yellow-400 text-sm font-bold uppercase tracking-widest transition-colors">
        GitHub
      </a>
    </nav>
  </div>

<script>
  function setupNavbar() {
    const toggleBtn = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');
    const icon = document.getElementById('menu-icon');

    if (toggleBtn && menu) {
      toggleBtn.addEventListener('click', () => {
        const isOpen = !menu.classList.contains('invisible');

        if (isOpen) {
          // Cerrar
          menu.classList.add('opacity-0', 'invisible', '-translate-y-4', 'pointer-events-none');
          menu.classList.remove('opacity-100', 'visible', 'translate-y-0', 'pointer-events-auto');
        } else {
          // Abrir
          menu.classList.remove('opacity-0', 'invisible', '-translate-y-4', 'pointer-events-none');
          menu.classList.add('opacity-100', 'visible', 'translate-y-0', 'pointer-events-auto');
        }
      });
    }
  }

  // Ejecución en Astro
  setupNavbar();
  document.addEventListener('astro:after-swap', setupNavbar);
  document.addEventListener('astro:page-load', setupNavbar);
</script>

<style>
  /* Opcional: un toque de rotación al icono cuando se abre */
  #menu-toggle[aria-expanded="true"] #menu-icon {
    transform: rotate(90deg);
  }
</style>