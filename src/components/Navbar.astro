---
// src/components/Navbar.astro
---
<header class="fixed top-0 w-full z-[100] border-b border-white/5 bg-black/60 backdrop-blur-xl">
  <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
    
    <a href="/" class="flex items-center gap-2 group shrink-0">
      <div class="w-8 h-8 bg-yellow-400 rounded-lg flex items-center justify-center shadow-[0_0_15px_rgba(250,204,21,0.3)] group-hover:scale-110 transition-transform">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="black" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
          <line x1="16" y1="2" x2="16" y2="6"></line>
          <line x1="8" y1="2" x2="8" y2="6"></line>
          <line x1="3" y1="10" x2="21" y2="10"></line>
        </svg>
      </div>
      <span class="text-white font-black italic uppercase tracking-tighter text-lg hidden sm:block">
        Calendarium<span class="text-yellow-400">.tech</span>
      </span>
    </a>

    <nav class="hidden md:flex items-center gap-6">
      <a href="/" class="text-white/60 hover:text-white text-[10px] font-bold uppercase tracking-widest transition-colors">Eventos</a>
      <a href="/contacto" class="text-white/60 hover:text-white text-[10px] font-bold uppercase tracking-widest transition-colors">
    Contacto
      </a>
      
      <div class="flex items-center gap-3 ml-4 border-l border-white/10 pl-6">
        <a href="/sumar-evento" class="px-4 py-2 border border-white/10 rounded-full text-[10px] font-black uppercase italic text-white/80 hover:bg-white/5 hover:border-white/30 transition-all">
          + Sumar Evento
        </a>
        <a href="/suscribirse" class="px-5 py-2 bg-yellow-400 text-black text-[10px] font-black uppercase italic rounded-full hover:bg-white hover:scale-105 transition-all shadow-[0_0_20px_rgba(250,204,21,0.2)]">
          Recibir Alertas
        </a>
      </div>
    </nav>

    <button id="menu-toggle" class="md:hidden text-white p-2 focus:outline-none" aria-label="Abrir menú">
      <svg id="menu-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="transition-transform duration-300">
        <line x1="3" y1="12" x2="21" y2="12" class="line-1"></line>
        <line x1="3" y1="6" x2="21" y2="6" class="line-2"></line>
        <line x1="3" y1="18" x2="21" y2="18" class="line-3"></line>
      </svg>
    </button>
  </div>

  <div id="mobile-menu" class="absolute top-16 left-0 w-full bg-black/95 border-b border-white/10 backdrop-blur-2xl overflow-hidden transition-all duration-300 ease-in-out opacity-0 invisible -translate-y-4 pointer-events-none md:hidden">
    <nav class="flex flex-col p-8 gap-6">
      <a href="/" class="text-white/70 hover:text-yellow-400 text-sm font-bold uppercase tracking-widest transition-colors border-b border-white/5 pb-2">Eventos</a>
      <a href="/sumar-evento" class="text-white/70 hover:text-yellow-400 text-sm font-bold uppercase tracking-widest transition-colors border-b border-white/5 pb-2">+ Sumar Evento</a>
      <a href="/suscribirse" class="px-6 py-4 bg-yellow-400 text-black text-center font-black uppercase italic rounded-xl hover:bg-white transition-all active:scale-95">Recibir Alertas</a>
      <a href="/contacto" class="text-white/40 text-center text-[10px] font-bold uppercase tracking-widest pt-4 hover:text-white transition-colors">Contacto</a>
    </nav>
  </div>
</header>

<script>
  function setupNavbar() {
    const toggleBtn = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');
    const menuIcon = document.getElementById('menu-icon');

    if (toggleBtn && menu) {
      toggleBtn.onclick = () => {
        const isClosed = menu.classList.contains('invisible');
        
        if (isClosed) {
          // Abrir
          menu.classList.remove('opacity-0', 'invisible', '-translate-y-4', 'pointer-events-none');
          menu.classList.add('opacity-100', 'visible', 'translate-y-0', 'pointer-events-auto');
          if (menuIcon) menuIcon.style.transform = 'rotate(90deg)';
        } else {
          // Cerrar
          menu.classList.add('opacity-0', 'invisible', '-translate-y-4', 'pointer-events-none');
          menu.classList.remove('opacity-100', 'visible', 'translate-y-0', 'pointer-events-auto');
          if (menuIcon) menuIcon.style.transform = 'rotate(0deg)';
        }
      };

      // Cerrar al hacer click en un link (para anchors como #footer)
      const links = menu.querySelectorAll('a');
      links.forEach(link => {
        link.onclick = () => {
          menu.classList.add('opacity-0', 'invisible', '-translate-y-4', 'pointer-events-none');
          menu.classList.remove('opacity-100', 'visible', 'translate-y-0', 'pointer-events-auto');
        };
      });
    }
  }

  // Inicializar en carga y tras cambios de página
  setupNavbar();
  document.addEventListener('astro:after-swap', setupNavbar);
  document.addEventListener('astro:page-load', setupNavbar);
</script>