---
// src/components/Footer.astro
const year = new Date().getFullYear();
---
<footer class="w-full py-10 mt-auto border-t border-white/5 bg-black/20 backdrop-blur-md">
  <div class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row justify-between items-center gap-8">
    
    <div class="text-center md:text-left">
      <p class="text-white/40 text-xs font-mono uppercase tracking-[0.3em]">
        &copy; {year} Calendarium<span class="text-yellow-400">.tech</span>
      </p>
      <p class="text-white/20 text-[10px] mt-2 italic font-light">
        Curado por <span class="text-white/40 hover:text-white transition-colors cursor-default">Nahuel</span> para la comunidad tech
      </p>
    </div>
    
    <div class="flex flex-col items-center md:items-end gap-4">
      <div class="flex gap-6">
        <a href="#" class="text-white/40 hover:text-yellow-400 transition-colors text-[10px] uppercase font-black italic tracking-widest">Contacto</a>
        <a href="#" class="text-white/40 hover:text-yellow-400 transition-colors text-[10px] uppercase font-black italic tracking-widest">Sumar Evento</a>
      </div>

      <div class="flex gap-4 items-center">
        <a href="#" target="_blank" class="text-white/20 hover:text-white transition-all transform hover:scale-110" aria-label="Instagram">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
          </svg>
        </a>

        <a href="#" target="_blank" class="text-white/20 hover:text-white transition-all transform hover:scale-110" aria-label="LinkedIn">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
            <rect x="2" y="9" width="4" height="12"></rect>
            <circle cx="4" cy="4" r="2"></circle>
          </svg>
        </a>
      </div>
    </div>

  </div>
</footer>