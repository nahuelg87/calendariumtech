---
// 1. Recibimos props (Mapeamos link_url de la DB a linkUrl)
const { 
  title = "Evento sin título", 
  date = "", 
  event_tags = [], 
  image_url = "", 
  location = "TBA", 
  link_url = "", // Cambiado para que coincida con la DB
  is_featured = false 
} = Astro.props;

// 2. Procesamiento de Tracks (Blindado)
const tracksList = event_tags?.map((t: any) => t.track_name).filter(Boolean) || [];
const allTracksString = tracksList.length > 0 ? tracksList.join(', ') : 'General';
const dataFilterString = tracksList.join(' ');

// 3. Lógica de Fecha (Blindada)
const safeDate = date || new Date().toISOString().split('T')[0];
const fechaEvento = new Date(safeDate + 'T00:00:00');
const hoy = new Date();
hoy.setHours(0, 0, 0, 0); 
const estaFinalizado = fechaEvento < hoy;

const fechaFormateada = fechaEvento.toLocaleDateString('es-AR', {
  day: '2-digit', month: 'short', year: 'numeric'
}).replace('.', '');

// 4. Lógica de Slug
const eventSlug = title.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "").replace(/\s+/g, '-').replace(/[^\w\-]+/g, '');
const fullShareUrl = `https://calendarium.tech/#${eventSlug}`;

// 5. Cloudinary
const CLOUD_NAME = import.meta.env.PUBLIC_CLOUDINARY_CLOUD_NAME;
const getOptimizedImage = (url: string) => {
  const cleanUrl = url?.trim() || '';
  if (!cleanUrl || !CLOUD_NAME) return 'https://images.unsplash.com/photo-1504384308090-c894fdcc538d?q=80&w=1000&auto=format&fit=crop';
  const transformations = "w_800,c_fill,g_auto,f_auto,q_auto";
  return cleanUrl.includes('cloudinary.com') ? cleanUrl.replace('/upload/', `/upload/${transformations}/`) : `https://res.cloudinary.com/${CLOUD_NAME}/image/fetch/${transformations}/${encodeURIComponent(cleanUrl)}`;
};
const optimizedUrl = getOptimizedImage(image_url);
---

<div data-card-track={dataFilterString} class={`event-card group reveal ${is_featured ? 'featured' : ''} ${estaFinalizado ? 'is-past' : ''}`}>
  {is_featured && !estaFinalizado && <span class="featured-badge">DESTACADO</span>}
  {estaFinalizado && <span class="past-badge">FINALIZADO</span>}

  <img src={optimizedUrl} alt={title} class="card-image" loading="lazy" />
  
  <div class="card-content">
    <div class="card-info">
      <div class="flex flex-wrap gap-2 mb-2">
        {tracksList.map((tName: string) => <span class="track-tag">{tName}</span>)}
        {tracksList.length === 0 && <span class="track-tag">General</span>}
      </div>
      <h3 class="card-title">{title}</h3>
      <p class="card-meta">{fechaFormateada} • {location}</p>
    </div>
    
    <div class="btn-container">
      {estaFinalizado ? (
        <button class="btn-inscribirse btn-finalizado" disabled>Finalizado</button>
      ) : (
        <div class="flex gap-2 items-center pointer-events-auto">
          <a href={link_url || '#'} target="_blank" class={`btn-inscribirse ${!link_url ? 'btn-disabled opacity-50' : ''}`}>
            {link_url ? 'Inscribirse' : 'Próximamente'}
          </a>
          
          <button class="btn-utility share-btn" data-title={title} data-url={fullShareUrl} title="Compartir">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg>
          </button>

          <div class="calendar-dropdown">
            <button class="btn-utility" title="Agendar">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
            </button>
          </div>
        </div>
      )}
    </div>
  </div>
</div>

<style>
  @reference "tailwindcss";
  .reveal { opacity: 0; transform: translateY(20px); transition: all 0.6s ease-out; }
  :global(.reveal.active) { opacity: 1 !important; transform: translateY(0) !important; }

  .event-card { position: relative; overflow: hidden; border-radius: 1.5rem; background: #0a0a0a; border: 1px solid rgba(255,255,255,0.05); min-height: 400px; display: flex; flex-direction: column; color: white; }
  .card-image { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0.3; z-index: 0; }
  .card-content { position: relative; z-index: 10; padding: 1.5rem; height: 100%; display: flex; flex-direction: column; justify-content: flex-end; background: linear-gradient(to top, rgba(0,0,0,1) 0%, rgba(0,0,0,0.5) 60%, transparent 100%); flex-grow: 1; pointer-events: none; }
  .card-info, .btn-container { pointer-events: auto; }
  .track-tag { font-size: 10px; color: #22d3ee; border: 1px solid rgba(34,211,238,0.3); padding: 2px 8px; border-radius: 4px; text-transform: uppercase; font-weight: bold; }
  .card-title { font-size: 1.4rem; font-weight: 800; margin: 0.5rem 0; line-height: 1.1; }
  .card-meta { font-size: 0.8rem; color: #888; }
  .btn-inscribirse { background: #facc15; color: black; font-weight: 900; padding: 0.6rem 1.2rem; border-radius: 0.5rem; font-size: 11px; text-transform: uppercase; text-decoration: none; }
  .btn-utility { background: rgba(255,255,255,0.1); color: #facc15; padding: 0.6rem; border-radius: 0.5rem; border: 1px solid rgba(255,255,255,0.1); }
  .featured-badge { position: absolute; top: 1rem; right: 1rem; background: #facc15; color: black; font-size: 10px; font-weight: bold; padding: 2px 8px; border-radius: 4px; z-index: 20; }
  .is-past { filter: grayscale(1); opacity: 0.7; }
</style>