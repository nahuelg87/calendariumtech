---
// src/components/EventCard.astro
const { title, date, track, imageUrl, location, linkUrl, is_featured } = Astro.props;

// 1. Lógica de Fecha (Comparación y Formateo)
// Agregamos T00:00:00 para evitar que la zona horaria te mueva el día
const fechaEvento = new Date(date + 'T00:00:00');
const hoy = new Date();
hoy.setHours(0, 0, 0, 0); 

const estaFinalizado = fechaEvento < hoy;

// Formateo para mostrar en la card (Ej: 20 oct 2026)
const fechaFormateada = fechaEvento.toLocaleDateString('es-AR', {
  day: '2-digit',
  month: 'short',
  year: 'numeric'
}).replace('.', '');

// 2. Configuración de Cloudinary (Variables de entorno)
const CLOUD_NAME = import.meta.env.PUBLIC_CLOUDINARY_CLOUD_NAME;

const getOptimizedImage = (url: string) => {
  const cleanUrl = url?.trim() || '';
  if (!cleanUrl) return 'https://images.unsplash.com/photo-1504384308090-c894fdcc538d?q=80&w=1000&auto=format&fit=crop';
  
  if (cleanUrl.startsWith('data:image')) return cleanUrl;
  if (!CLOUD_NAME) return cleanUrl;

  const transformations = "w_800,c_fill,g_auto,f_auto,q_auto";

  if (cleanUrl.includes('cloudinary.com')) {
    return cleanUrl.replace('/upload/', `/upload/${transformations}/`);
  }

  return `https://res.cloudinary.com/${CLOUD_NAME}/image/fetch/${transformations}/${encodeURIComponent(cleanUrl)}`;
};

const optimizedUrl = getOptimizedImage(imageUrl);
---

<div 
  data-card-track={track} 
  class={`event-card group reveal ${is_featured ? 'featured' : ''} ${estaFinalizado ? 'is-past' : ''}`}
>
  {is_featured && !estaFinalizado && <span class="featured-badge">DESTACADO</span>}
  {estaFinalizado && <span class="past-badge">FINALIZADO</span>}

  <img 
    src={optimizedUrl} 
    alt={title}
    class="card-image"
    loading="lazy"
  />
  
  <div class="card-content">
    <div class="card-info">
      <span class="track-tag">{track}</span>
      <h3 class="card-title">{title}</h3>
      <p class="card-meta">{fechaFormateada} • {location}</p>
    </div>
    
    <div class="btn-container">
      {estaFinalizado ? (
        <button class="btn-inscribirse btn-finalizado" disabled>
          Finalizado
        </button>
      ) : linkUrl ? (
        <a href={linkUrl} target="_blank" class="btn-inscribirse">
          Inscribirse
        </a>
      ) : (
        <button class="btn-inscribirse btn-disabled" disabled>
          Próximamente
        </button>
      )}
    </div>
  </div>
</div>

<style>
  /* --- 1. LÓGICA DE REVELADO --- */
  .reveal {
    opacity: 0;
    transform: translateY(30px) scale(0.95);
    transition: opacity 0.8s ease-out, transform 0.8s cubic-bezier(0.2, 0.8, 0.2, 1);
    will-change: opacity, transform;
  }

  :global(.reveal.active) {
    opacity: 1 !important;
    transform: translateY(0) scale(1) !important;
  }

  /* --- 2. ESTILO BASE Y DESTACADOS --- */
  .event-card {
    position: relative;
    overflow: hidden;
    border-radius: 2rem;
    background: #111;
    border: 1px solid rgba(255, 255, 255, 0.05);
    transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275), border-color 0.3s ease, box-shadow 0.3s ease;
    min-height: 400px;
    display: flex;
    flex-direction: column;
    z-index: 1;
  }

  .event-card.featured {
    border: 1px solid rgba(250, 204, 21, 0.3);
    background: linear-gradient(145deg, #111 0%, #1a1a05 100%);
  }

  .event-card:hover {
    transform: scale(1.04) !important;
    border-color: rgba(34, 211, 238, 0.3);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
    z-index: 20;
  }

  .event-card.featured:hover {
    border-color: #facc15;
    box-shadow: 0 10px 30px rgba(250, 204, 21, 0.1);
  }

  /* --- 3. IMAGEN Y ESTADOS --- */
  .card-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.2;
    filter: grayscale(1) brightness(0.6);
    transition: opacity 0.6s ease, filter 0.6s ease;
  }

  :global(.reveal.active) .card-image {
    opacity: 0.5;
    filter: grayscale(0.4) brightness(0.8);
  }

  .event-card:hover .card-image {
    opacity: 1 !important;
    filter: grayscale(0) brightness(1) !important;
  }

  /* Opacidad para eventos pasados */
  .event-card.is-past {
    filter: grayscale(1);
    opacity: 0.6;
  }

  /* --- 4. CONTENIDO Y BADGES --- */
  .card-content {
    position: relative;
    z-index: 10;
    padding: 2rem;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    background: linear-gradient(to top, rgba(0,0,0,0.9) 20%, transparent 100%);
    flex-grow: 1;
    pointer-events: none;
  }

  .track-tag {
    font-size: 10px;
    font-weight: bold;
    letter-spacing: 0.2em;
    color: #22d3ee;
    text-transform: uppercase;
  }

  .card-title {
    font-size: 1.5rem;
    font-weight: bold;
    color: white;
    line-height: 1.2;
    margin: 0.25rem 0;
  }

  .card-meta {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.5);
  }

  .featured-badge, .past-badge {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    font-size: 9px;
    font-weight: 900;
    padding: 4px 10px;
    border-radius: 0.5rem;
    z-index: 30;
    letter-spacing: 1px;
  }

  .featured-badge { background: #facc15; color: black; }
  .past-badge { background: #333; color: #888; }

  /* --- 5. BOTONES (ESTADOS) --- */
  .btn-inscribirse {
    pointer-events: auto;
    margin-top: 1.5rem;
    background: #facc15;
    color: black;
    font-size: 11px;
    font-weight: 900;
    text-transform: uppercase;
    font-style: italic;
    padding: 0.6rem 1.2rem;
    border-radius: 0.5rem;
    width: fit-content;
    text-decoration: none;
    display: inline-block;
    transform: scale(0);
    transition: transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1), background-color 0.2s ease;
  }

  :global(.reveal.active) .btn-inscribirse {
    transform: scale(1);
  }

  .btn-disabled {
    background: rgba(255, 255, 255, 0.1) !important;
    color: rgba(255, 255, 255, 0.3) !important;
    cursor: not-allowed;
  }

  .btn-finalizado {
    background: transparent !important;
    color: rgba(255, 255, 255, 0.4) !important;
    border: 1px solid rgba(255, 255, 255, 0.1);
    text-decoration: line-through;
    cursor: not-allowed;
  }

  .btn-inscribirse:hover:not(:disabled) {
    background-color: white;
  }

  /* --- 6. MODO LISTA --- */
  :global(#events-container.flex-col) .event-card {
    min-height: 90px !important;
    height: 90px !important;
    border-radius: 1rem !important;
    margin-bottom: 0.75rem;
    flex-direction: row !important;
  }

  :global(#events-container.flex-col) .card-image {
    position: relative !important;
    width: 70px !important;
    height: 70px !important;
    margin: 10px;
    border-radius: 8px;
    opacity: 1 !important;
    filter: grayscale(0) !important;
  }

  :global(#events-container.flex-col) .card-content {
    background: none !important;
    padding: 0 1.5rem 0 0 !important;
    flex-direction: row !important;
    align-items: center !important;
    justify-content: space-between !important;
    min-height: 90px !important;
  }

  :global(#events-container.flex-col) .btn-inscribirse {
    margin-top: 0 !important;
    transform: scale(1) !important;
  }
</style>